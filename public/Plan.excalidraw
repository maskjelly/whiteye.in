      "link": null,
      "locked": false,
      "text": "AI Automated Call Customer Agents - auto regression with new business specific on call learning and improvements\n",
      "fontSize": 14.566088849002268,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "AI Automated Call Customer Agents - auto regression with new business specific on call learning and improvements\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "goBEybbU9Gw6aVT0KBolh",
      "type": "text",
      "x": -97.23531529516674,
      "y": -3655.0057845393217,
      "width": 917.8913593210665,
      "height": 109.24566636751702,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b5p",
      "roundness": null,
      "seed": 9898941,
      "version": 674,
      "versionNonce": 801697341,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1737658968303,
      "link": null,
      "locked": false,
      "text": "It Will learn about the businesses users and what they usually ask \nthere will be a dashboard of what it thinks it has nailed it and what it thinks its not perfect in\n\n* it will gather keyword data and understand on what terms what could be asked\n* Linked to businesses stock inventory data - will be updated and can update users on whats available and also can place orders\n* (answer queries and refund if confirmed)",
      "fontSize": 14.566088849002268,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "It Will learn about the businesses users and what they usually ask \nthere will be a dashboard of what it thinks it has nailed it and what it thinks its not perfect in\n\n* it will gather keyword data and understand on what terms what could be asked\n* Linked to businesses stock inventory data - will be updated and can update users on whats available and also can place orders\n* (answer queries and refund if confirmed)",
      "autoResize": true,
      "lineHeight": 1.25
    },
