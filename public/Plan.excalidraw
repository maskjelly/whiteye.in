      "isDeleted": false,
      "boundElements": null,
      "updated": 1737657064962,
      "link": null,
      "locked": false,
      "text": "AI Education cannot be our only market - putting all our eggs in one basket is a death wish\n\nwe will be selling shovels in the forever rush of silkroad's history , people were assured to \nprofits by selling carts , donkeys , maps , water, food and all this that the travellers and \ntrade routes required for survival \n\n",
      "fontSize": 15.575303838434595,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "AI Education cannot be our only market - putting all our eggs in one basket is a death wish\n\nwe will be selling shovels in the forever rush of silkroad's history , people were assured to \nprofits by selling carts , donkeys , maps , water, food and all this that the travellers and \ntrade routes required for survival \n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
