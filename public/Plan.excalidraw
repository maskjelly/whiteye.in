    {
      "id": "WMZ3mEaWVs6CSkY0JJxe_",
      "type": "text",
      "x": -6769.779687877161,
      "y": -1810.1497143751894,
      "width": 663.4388559708747,
      "height": 82.97288333478024,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "BqyLSH0VBXkco0AwIqfHF",
        "9UcKZofn-PBNtv4S1L9FW"
      ],
      "frameId": null,
      "index": "b2Vze",
      "roundness": null,
      "seed": 1820138680,
      "version": 2301,
      "versionNonce": 1155808349,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1737655245026,
      "link": null,
      "locked": false,
      "text": "Cold email outreach automation , have a list of client , just give the task on what needs to be done , you will get everyone a personal cold \noutreach email in seconds and every email will be tracked for response and when the response comes through \n           -------------------------------- features ----------------------------------\n            * You get a personal email about it\n            * you can setup some action with respect to that\n            * if the email is about auto scheduling meetings then you get the meetings auto scheduled via cal.com ?\n           ",
      "fontSize": 9.482615238260601,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Cold email outreach automation , have a list of client , just give the task on what needs to be done , you will get everyone a personal cold \noutreach email in seconds and every email will be tracked for response and when the response comes through \n           -------------------------------- features ----------------------------------\n            * You get a personal email about it\n            * you can setup some action with respect to that\n            * if the email is about auto scheduling meetings then you get the meetings auto scheduled via cal.com ?\n           ",
      "autoResize": false,
      "lineHeight": 1.25
    },
