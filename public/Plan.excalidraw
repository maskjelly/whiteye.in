      "isDeleted": false,
      "boundElements": null,
      "updated": 1737658968303,
      "link": null,
      "locked": false,
      "text": "It will be guided by user and will have sudden [switch] where the real human\ncan take over the calls at any given moment if it sees things switching and \nthe AI will learn on what it went wrong and improve it self on spot\n\nIf the business is not satisfied with the responses and wants exact responses\nthey can go to call logs and rate every responses to queries and AI will be \nupdated on that new rating \n\n",
      "fontSize": 14.56608884900227,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "It will be guided by user and will have sudden [switch] where the real human\ncan take over the calls at any given moment if it sees things switching and \nthe AI will learn on what it went wrong and improve it self on spot\n\nIf the business is not satisfied with the responses and wants exact responses\nthey can go to call logs and rate every responses to queries and AI will be \nupdated on that new rating \n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
